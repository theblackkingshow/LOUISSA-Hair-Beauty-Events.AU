{
  "buildCommand": "true",
  "outputDirectory": "./",
  "public": true,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/:path*.html"
    },
    {
      "source": "/:path*/",
      "destination": "/:path*.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}
